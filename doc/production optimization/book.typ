  align(center)[#table(
    columns: 2,
    align: (auto,auto,),
    table.header([API Range], [Classification],),
    table.hline(),
    [\> 40], [Light oil / condensate],
    [30--40], [Medium oil],
    [22--30], [Heavy oil],
    [\< 22], [Extra heavy oil],
  )]
