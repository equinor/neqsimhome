    proc.add(pipe)
    proc.run()

    out_P = pipe.getOutletStream().getPressure("bara")
    out_T = pipe.getOutletStream().getTemperature("C")
    dP = 120.0 - out_P
    print(f"Diameter: {d_inch}\"  dP: {dP:.1f} bar  Outlet T: {out_T:.1f} °C")
