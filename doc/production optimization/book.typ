    [#strong[Mechanical Refrigeration]], [80--95%], [40--70%], [Medium], [Medium], [Moderate recovery, small plants],
    [#strong[Turboexpander]], [95--99%], [80--95%+], [Low (net)], [High], [Deep recovery, large plants],
