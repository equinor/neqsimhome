$ U_i \( x \) lt.eq U_(i \, upright("max")) \, quad upright("for all equipment ") i $

#strong[Quality constraints:]

$ upright("HHV") \( x \) gt.eq upright("HHV")_(upright("min")) quad upright("(gas heating value)") $

