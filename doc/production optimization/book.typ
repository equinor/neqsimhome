        "n-pentane": 0.3, "n-hexane": 0.2, "CO2": 3.0,
        "nitrogen": 1.3
    },
    "Year 10 (lean)": {
        "methane": 88.0, "ethane": 4.5, "propane": 2.0,
        "i-butane": 0.5, "n-butane": 0.8, "CO2": 2.5,
        "nitrogen": 1.7
    }
}

print(f"{'Scenario':<22} {'MW':>6} {'Power':>8} {'T_out':>7} "
      f"{'Head':>8} {'PR':>5}")
