    arrival_T = pipe.getOutletStream().getTemperature("C")
    arrival_P = pipe.getOutletStream().getPressure("bara")
    results.append({
        "distance_km": dist,
        "arrival_T_C": round(arrival_T, 1),
        "arrival_P_bara": round(arrival_P, 1),
        "dP_bar": round(180.0 - arrival_P, 1)
